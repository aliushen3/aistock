# AiStock 环境变量模板
# 复制为 aistock.env 后修改；chmod 600 aistock.env

# --- 数据库（生产必须 PostgreSQL）---
DATABASE_URL=postgresql://aistock:CHANGE_ME@127.0.0.1:5432/aistock
# AISTOCK_SQLITE=1

# --- Ontology 启动模式 ---
# false=空图启动（生产推荐）；true=首次建库灌入 demo 种子 seed_ai_compute.json
LOAD_DEMO_SEED=false

# --- Neo4j ---
NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=CHANGE_ME
USE_NEO4J_TRAVERSAL=auto

# --- Redis / Celery ---
REDIS_URL=redis://127.0.0.1:6379/0
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/0

# --- Qdrant ---
QDRANT_URL=http://127.0.0.1:6333
QDRANT_COLLECTION=aistock_evidence
QDRANT_DOCUMENTS_COLLECTION=aistock_documents

# --- MinIO ---
MINIO_ENDPOINT=127.0.0.1:9000
MINIO_ACCESS_KEY=CHANGE_ME
MINIO_SECRET_KEY=CHANGE_ME
MINIO_BUCKET=aistock-docs

# --- LLM（Agent / GraphRAG）---
# LLM_API_KEY=sk-xxx
# DEEPSEEK_API_KEY=sk-xxx
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat
LLM_ENABLED=auto

# --- Embedding ---
EMBEDDING_ENABLED=auto
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536

# --- 数据适配器（按类型）---
# market: mock | akshare | tushare | auto（auto: tushare 主 -> akshare 备，生产推荐）
DATA_ADAPTER=mock
DATA_ADAPTER_MARKET=mock
DATA_ADAPTER_ANNOUNCEMENT=mock
# metrics: mock | akshare（期货主力材料行情，映射见 data/material_contracts.json）
DATA_ADAPTER_METRICS=mock
# financial: mock | tushare（需 2000 积分：income + fina_indicator）
DATA_ADAPTER_FINANCIAL=mock
# research: mock | em（AkShare 东财研报，免费）
DATA_ADAPTER_RESEARCH=mock
# constituent: mock | akshare（板块成分股 → OntCompany 真实代码）
DATA_ADAPTER_CONSTITUENT=mock
# 公告/研报回看天数
ANNOUNCEMENT_LOOKBACK_DAYS=90
RESEARCH_LOOKBACK_DAYS=90
# 生产推荐：
# DATA_ADAPTER_MARKET=auto
# DATA_ADAPTER_ANNOUNCEMENT=akshare
# DATA_ADAPTER_FINANCIAL=tushare
# DATA_ADAPTER_RESEARCH=em
# DATA_ADAPTER_CONSTITUENT=akshare
# TUSHARE_TOKEN=your_tushare_pro_token
# AKSHARE_RATE_LIMIT_SEC=0.5
# TUSHARE_RATE_LIMIT_SEC=0.3
# DATA_ADAPTER_ANNOUNCEMENT=cninfo
# CNINFO_API_URL=

# 行情抓取网络兜底（免费源 IPv6 不通/限流时）
MARKET_FORCE_IPV4=true
MARKET_HTTP_MAX_RETRY=3
MARKET_HTTP_RETRY_BACKOFF_SEC=1.0
