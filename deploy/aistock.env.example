# AiStock 环境变量模板
# 复制为 aistock.env 后修改；chmod 600 aistock.env

# --- 数据库（生产必须 PostgreSQL）---
DATABASE_URL=postgresql://aistock:CHANGE_ME@127.0.0.1:5432/aistock
# AISTOCK_SQLITE=1

# --- Neo4j ---
NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=CHANGE_ME
USE_NEO4J_TRAVERSAL=auto

# --- Redis / Celery ---
REDIS_URL=redis://127.0.0.1:6379/0
CELERY_BROKER_URL=redis://127.0.0.1:6379/0
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/0

# --- Qdrant ---
QDRANT_URL=http://127.0.0.1:6333
QDRANT_COLLECTION=aistock_evidence
QDRANT_DOCUMENTS_COLLECTION=aistock_documents

# --- MinIO ---
MINIO_ENDPOINT=127.0.0.1:9000
MINIO_ACCESS_KEY=CHANGE_ME
MINIO_SECRET_KEY=CHANGE_ME
MINIO_BUCKET=aistock-docs

# --- LLM（Agent / GraphRAG）---
# LLM_API_KEY=sk-xxx
# DEEPSEEK_API_KEY=sk-xxx
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat
LLM_ENABLED=auto

# --- Embedding ---
EMBEDDING_ENABLED=auto
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536

# --- 数据适配器 ---
DATA_ADAPTER=mock
# WIND_API_KEY=
# WIND_API_URL=http://127.0.0.1:8088/wind
# CNINFO_API_URL=
